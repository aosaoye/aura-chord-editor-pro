generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id      String  @id @default(uuid())
  clerkId String  @unique // The ID provided by Clerk Authentication
  email   String  @unique
  name      String?
  bio       String?   @db.Text
  avatarUrl String?
  bannerUrl String?
  website   String?
  instagram String?
  youtube   String?

  // Suscripción Stripe
  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  // Marketplace Stripe Connect
  stripeConnectAccountId String? @unique @map(name: "stripe_connect_account_id")

  songs       Song[]
  devotionals Devotional[]

  // Relaciones de Comunidad, Seguidores y Notificaciones
  followers     Follows[]      @relation("following")
  following     Follows[]      @relation("follower")
  notifications Notification[]
  songRatings   SongRating[]
  purchases     Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema.prisma (Fragmento)

model Song {
  id     String @id @default(uuid())
  userId String // Foreign key to User
  user   User   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  title      String
  bpm        Int    @default(120)
  rawLyrics  String @db.Text
  
  // 🚀 SENIOR FIX: Usamos el tipo nativo Json en lugar de String @db.Text
  // Esto permite hacer queries avanzadas dentro del JSON en el futuro.
  parsedData Json   

  isPublic Boolean @default(false)
  price    Float?  @default(0)

  devotionals  DevotionalSong[]
  translations SongTranslation[]
  ratings      SongRating[]
  purchases    Purchase[]
  interactions Interaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Follows {
  follower   User   @relation("follower", fields: [followerId], references: [clerkId], onDelete: Cascade)
  followerId String

  following   User   @relation("following", fields: [followingId], references: [clerkId], onDelete: Cascade)
  followingId String

  createdAt DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Devotional {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  title String
  date  DateTime?

  songs DevotionalSong[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DevotionalSong {
  id           String     @id @default(uuid())
  devotionalId String
  devotional   Devotional @relation(fields: [devotionalId], references: [id], onDelete: Cascade)
  songId       String
  song         Song       @relation(fields: [songId], references: [id], onDelete: Cascade)
  order        Int        @default(0)

  @@index([devotionalId])
  @@index([songId])
}

model SongRating {
  id        String   @id @default(uuid())
  value     Int // Valor de estrellas (1-5)
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, songId]) // Un usuario solo puede puntuar una obra una vez
  @@index([songId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  type      String   @default("system")
  message   String
  link      String?  // Optional link
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Interaction {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  type      String   // "view" | "like" | "purchase" | "skip"
  value     Float    // peso (e.g., 1, 3, 10)
  createdAt DateTime @default(now())

  @@index([userId, songId])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  amount          Float
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
}

model SongTranslation {
  id          String @id @default(uuid())
  songId      String
  song        Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  locale      String // "es", "en", "ja", etc.
  title       String
  description String? @db.Text

  @@unique([songId, locale])
  @@index([songId])
}
